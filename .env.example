# Credenciais Moloni do cliente. Copiar para .env e preencher no onboarding.
# São as mesmas variáveis usadas em izigo-backend/routes/moloni.js.
# Obtêm-se na conta Moloni do cliente (developer app + utilizador com acesso à API).

MOLONI_CLIENT_ID=
MOLONI_CLIENT_SECRET=
MOLONI_USERNAME=
MOLONI_PASSWORD=
MOLONI_COMPANY_ID=

# Opcional. Default: ./downloads
DOWNLOAD_DIR=./downloads
